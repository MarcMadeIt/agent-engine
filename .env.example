# Default LLM provider: mistral | anthropic (Claude) | google (Gemini).
# This is the fallback for any role not assigned in LLM_ROLE_MODELS below.
LLM_PROVIDER=mistral
# Optional default model override (defaults: mistral-large-latest / claude-sonnet-4-6 / gemini-2.0-flash)
LLM_MODEL=

MISTRAL_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Per-role models — configure each "team member" with its own provider/model/temperature.
# JSON map of role -> { provider, model?, temperature? }. Unassigned roles use LLM_PROVIDER above.
# Roles: architect, worker, lead, critic, builder, implementer, analyst, router, replan, decompose, tester.
# Every provider you reference needs its API key set (e.g. a google role needs GOOGLE_API_KEY).
# temperature is 0 (deterministic, e.g. a critic) … 2; omitted = 0.2. Newer Claude (Opus 4.7/4.8) ignores it.
# Example: Mistral plans, a deterministic Gemini critic, Claude writes the code.
# LLM_ROLE_MODELS={"architect":{"provider":"mistral"},"critic":{"provider":"google","model":"gemini-2.0-flash","temperature":0},"implementer":{"provider":"anthropic","model":"claude-sonnet-4-6"}}
LLM_ROLE_MODELS=

# Prompt caching for Claude (M3 Trin 4). true|false, default true. Adds a top-level
# ephemeral cache breakpoint to every Anthropic call; the API caches the longest
# stable prefix (tools + system + transcript) and re-reads it at ~0.1x on the next
# call. Big win in the implementer/tester ReAct loop. Anthropic only (Mistral/Gemini
# ignore it). Pure cost reduction — turn off only to measure raw uncached tokens.
LLM_PROMPT_CACHE=true

# Supabase (EU). URL + service key feed the supabase-js client in @arzonic/agent-shared.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Postgres connection string for the LangGraph checkpointer (Supabase > Settings > Database).
# When set, runs persist and can be resumed. When empty, the in-memory MemorySaver is used.
SUPABASE_DB_URL=

# Guardrails
MAX_ROUNDS=3
RUN_TOKEN_BUDGET=
RUN_TIMEOUT_MS=300000

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=

# --- apps/api (Phase 2) ---
# Bearer key product apps must send. Server-side only — never expose to a browser.
AGENT_API_KEY=
API_PORT=8787
# Comma-separated allowed origins (Ranky/Bravy domains + localhost in dev). Empty = CORS off.
API_CORS_ORIGINS=
# Base dirs the worker may analyze; the repo picker lists git repos under these.
# Local: /Users/<you>/Documents/GitHub  ·  VPS: /opt   (comma-separated for several)
REPO_ALLOWED_ROOTS=
# Commands the worker's run_check tool may run (pnpm scripts). Default shown.
REPO_ALLOWED_CHECKS=test,lint,typecheck,build
# Executables a mission may run via runCommand (M2 write-tools, no shell). Default shown.
REPO_ALLOWED_COMMANDS=git,node,pnpm,npm,npx

# --- autonomous missions (§5) — drives the agent-mission-worker process ---
# Hard token ceiling per mission (empty = only the per-mission budget applies).
MISSION_TOKEN_BUDGET=
# Backstop iteration cap per mission (empty = unbounded by iterations).
MISSION_MAX_ITERATIONS=
# Consecutive no-progress iterations before the mission stops.
MISSION_NOPROGRESS_LIMIT=3
# Times one item may fail before it is parked for a human (thrash guard).
MISSION_THRASH_LIMIT=3
# Items run concurrently per mission, each in its own worktree (merge stays serial). Default 1.
MISSION_CONCURRENCY=1
# Drift-robustness (M3 Trin 3). How many times a model call retries a TRANSIENT
# error (rate-limit/5xx/timeout) with exponential backoff + jitter. Default 6.
MISSION_LLM_MAX_RETRIES=6
# How many times the controller re-queues an item whose run throws a transient
# infra error before parking it for a human (a persistent outage still terminates).
# Keep below MISSION_NOPROGRESS_LIMIT to park with a recorded reason; above it to
# prefer a resumable no-progress stop.
MISSION_REQUEUE_LIMIT=2
# Adversarial review cycles per item (M3 ★): critic challenges the implementer's
# diff and loops back on a fail. 0 = lone implementer (pre-★). Default 1.
MISSION_REVIEW_ROUNDS=1
# Author a test that exercises each item before verification (M3 Trin 2), so
# "green" means a real test passed, not just that it compiles. true|false.
# Pair with a "test" check in MISSION_CHECKS; pick its model via the `tester` role.
MISSION_AUTHOR_TESTS=false
# Checks the Verifier runs per item — pass/fail is the truth source for "done".
MISSION_CHECKS=typecheck,test
# Extra phrases that force an item to high-risk (parked). Comma-separated.
MISSION_HIGH_RISK_PATTERNS=
# How often the worker scans for running missions (ms).
MISSION_WORKER_POLL_MS=5000
